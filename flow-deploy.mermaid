%% Flujo de deploy del IDP: Git -> ArgoCD -> CAPI/KubeVirt -> vCluster -> tenant
%% Fuente del diagrama embebido en ACCESO-Y-PRUEBAS-CLUSTERS.md
flowchart TD
    GIT["Git: villadalmine/vcluster-idp.git\n(única fuente de verdad)"]:::git

    subgraph MGMT["CLUSTER MANAGEMENT (k8s real, etcd HA)"]
      ARGO["ArgoCD (raíz)"]:::argo
      PR["platform-root\n(app-of-apps)"]:::app
      ADDONS["addons: CAPI Operator · Crossplane v2 ·\nKubeVirt · CDI · CAAPH · provider-kubernetes"]:::app
      FH["fleet-hostclusters\n(lee clusters/homelab/host-*.yaml)"]:::app
      XR["HostCluster XR\n(role, region, cni, cpInitTimeout, nodeArch...)"]:::xr
      COMP["Crossplane Composition\n→ envuelve cada objeto CAPI en\nprovider-kubernetes Object\n(cede ownership a CAPI)"]:::xr
      CAPI["CAPI: Cluster · KubeadmControlPlane ·\nMachineDeployment · KubevirtMachineTemplate"]:::capi
      TC["tenants centralizados\n(cli/platform → tenants/<env>/<t>.yaml)\n→ vcluster-tenant-* + wl-tenant-*"]:::tenant
    end

    subgraph T7910["srv-t7910 (KubeVirt host, VM disks en Longhorn)"]
      VM["VMs: CP + workers\n(arrancan por kubeadm)"]:::vm
      CRS["ClusterResourceSet\n→ instala el CNI (Calico / Cilium / Calico-VXLAN)"]:::vm
      CAAPH["CAAPH HelmChartProxy\n→ instala ArgoCD en clusters role=management"]:::vm
    end

    subgraph REG["CLUSTER REGIONAL (ej host-euw1, su PROPIO ArgoCD)"]
      RR["region-root (sembrado por CRS)\npath = clusters/regions/_base\n+ kustomize.patches (REGION→eu-west1)"]:::argo
      VAS["vclusters-<region> (ApplicationSet)\n1 vCluster por tenant"]:::app
      WAS["workloads-<region> (ApplicationSet)\ncharts/tenant DENTRO del vCluster"]:::app
      REGI["vcluster-register (CronJob)\nregistra el vCluster como destino ArgoCD"]:::app
      VC["vCluster (loft)\nvcluster-<tenant>-<env>-0"]:::vc
      WL["Workload del tenant\npostgres + customer-api + customer-web"]:::tenant
    end

    GIT --> ARGO --> PR
    PR --> ADDONS
    PR --> FH --> XR --> COMP --> CAPI
    CAPI -->|crea VMs| VM
    VM --> CRS
    VM --> CAAPH
    CAAPH -->|instala ArgoCD regional| RR
    GIT -. "lee _base + tenants/<region>" .-> RR
    RR --> VAS --> VC
    RR --> WAS --> WL
    RR --> REGI -.->|registra destino| WAS
    VC --> WL
    PR --> TC

    classDef git fill:#222,color:#fff,stroke:#888;
    classDef argo fill:#1d4ed8,color:#fff,stroke:#1e3a8a;
    classDef app fill:#2563eb,color:#fff,stroke:#1e3a8a;
    classDef xr fill:#7c3aed,color:#fff,stroke:#4c1d95;
    classDef capi fill:#0891b2,color:#fff,stroke:#155e75;
    classDef vm fill:#b45309,color:#fff,stroke:#78350f;
    classDef vc fill:#059669,color:#fff,stroke:#064e3b;
    classDef tenant fill:#16a34a,color:#fff,stroke:#14532d;
