#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════
# fleet-test — test & DEMONSTRATE the KubeVirt fleet end-to-end (multi-cluster)
# ───────────────────────────────────────────────────────────────────────────
# The host clusters expose their API as a ClusterIP (only routable from the
# management's pod network), so this script talks to each one through a *jump
# pod* (idempotent: recreated when not Running). From the management cluster:
#
#   cli/fleet-test check [cluster|all]      # validate every layer (nodes/CNI/DNS/ArgoCD/vCluster)
#   cli/fleet-test vclusters                # list ALL vClusters across every host cluster
#   cli/fleet-test vc-info                  # RICH per-vCluster card: git source+domain, workloads, HTTPRoute, access
#   cli/fleet-test vms                      # list every KubeVirt VM and the real hypervisor node it runs on
#   cli/fleet-test kc <cluster> <args...>   # kubectl passthrough to a host cluster
#   cli/fleet-test vc <cluster> <vc> <args> # kubectl INSIDE a vCluster
#   cli/fleet-test dns <cluster>            # cross-node DNS test (the MTU validation)
#   cli/fleet-test demo                     # full sweep (check all + vclusters)
#   cli/fleet-test clean                    # delete the jump/test pods
#
# NOTE: the Root / management cluster is NOT a target here — it is the local
# kube-context this CLI runs from (reached directly), not a created host cluster
# behind a jump pod. fleet-test only targets the host clusters it provisioned.
# ═══════════════════════════════════════════════════════════════════════════
set -uo pipefail
NS=fleet
IMG=alpine/k8s:1.31.0

# Clusters DISCOVERED dynamically (zero hardcode): every reachable host/workload cluster exposes its
# admin kubeconfig as a secret "<cluster>-kubeconfig" in the management namespace — CAPI creates it for
# the ones the Root manages, and the recursive rung (mgmt-child) leaves a copy there. Add or remove a
# cluster and the tool follows automatically. ALL is computed at startup (before the dispatch).
discover_clusters() {
  kubectl -n "$NS" get secret -o name 2>/dev/null | sed -n 's@^secret/\(.*\)-kubeconfig$@\1@p' | sort -u
}

c0() { printf "\033[%sm%s\033[0m" "$1" "$2"; }
hdr(){ echo; echo "$(c0 '1;36' "══ $* ══")"; }
ok() { echo "  $(c0 '1;32' '✔') $*"; }
no() { echo "  $(c0 '1;31' '✗') $*"; }
inf(){ echo "  $(c0 '1;34' '·') $*"; }
warn(){ echo "  $(c0 '1;33' '⚠') $*"; }
li() { echo "      - $*"; }   # indented list item under a check

fleet_banner() {
  hdr "FLEET TARGETS ($(echo "$ALL" | wc -w | tr -d ' ') host clusters)"
  echo "$ALL" | while read -r c; do [ -n "$c" ] && li "$c"; done
  inf "The Root/management cluster is omitted on purpose: it is the local kube-context this CLI runs"
  inf "from (reached directly), not a created host cluster behind a jump pod."
}

ensure_jump() { # idempotent: (re)create the jump pod when it is not Running
  local c=$1
  kubectl -n $NS get secret "${c}-kubeconfig" >/dev/null 2>&1 || { warn "$c: no kubeconfig (does the cluster exist?)"; return 1; }
  # Recreate when the pod is NOT Running: the `sleep` expires and the pod goes Completed; the old
  # reuse-by-name saw it "present" and never recreated it -> the Ready wait hung and check failed silently.
  local phase; phase=$(kubectl -n $NS get pod "jump-$c" -o jsonpath='{.status.phase}' 2>/dev/null)
  if [ "$phase" != "Running" ]; then
    kubectl -n $NS delete pod "jump-$c" --ignore-not-found >/dev/null 2>&1
    kubectl -n $NS apply -f - >/dev/null 2>&1 <<EOF
apiVersion: v1
kind: Pod
metadata: { name: jump-$c, namespace: $NS, labels: { app: fleet-test-jump } }
spec:
  restartPolicy: Never
  volumes: [{ name: kc, secret: { secretName: ${c}-kubeconfig } }]
  containers: [{ name: p, image: $IMG, command: ["sleep","7200"], volumeMounts: [{ name: kc, mountPath: /kc }] }]
EOF
  fi
  kubectl -n $NS wait --for=condition=Ready "pod/jump-$c" --timeout=120s >/dev/null 2>&1
}

kc() {
  local c=$1; shift
  if [ -t 0 ]; then
    timeout 30 kubectl -n $NS exec "jump-$c" -- kubectl --kubeconfig=/kc/value "$@" 2>&1
  else
    timeout 30 kubectl -n $NS exec -i "jump-$c" -- kubectl --kubeconfig=/kc/value "$@" 2>&1
  fi
}

# q <cluster> <kubectl args> — run against a cluster: "@root" = the local management cluster (direct),
# anything else = a host cluster through its jump pod. Lets vc-info cover the centralized vClusters
# (on the Root) AND the regional/recursive ones (on host clusters) with one code path.
q() {
  local c=$1; shift
  if [ "$c" = "@root" ]; then timeout 30 kubectl "$@" 2>&1; else kc "$c" "$@"; fi
}

# Map a guest node (a KubeVirt VM) to the REAL hypervisor node it runs on. The guest node name equals the
# VMI name; the VMI lives in the management cluster (any namespace) and .status.nodeName is the bare-metal node.
vmi_node() {
  kubectl get vmi -A --field-selector "metadata.name=$1" -o jsonpath='{.items[0].status.nodeName}' 2>/dev/null
}

dns_test() { # cross-node DNS test (worker→CoreDNS) — the MTU validation. Idempotent.
  local c=$1
  kc "$c" -n default delete pod fleet-dnstest --ignore-not-found >/dev/null 2>&1
  kc "$c" -n default apply -f - >/dev/null 2>&1 <<'EOF'
apiVersion: v1
kind: Pod
metadata: { name: fleet-dnstest, namespace: default }
spec:
  affinity: { nodeAffinity: { requiredDuringSchedulingIgnoredDuringExecution: { nodeSelectorTerms: [{ matchExpressions: [{ key: node-role.kubernetes.io/control-plane, operator: DoesNotExist }] }] }}}
  containers: [{ name: c, image: busybox:1.36, command: ["sh","-c","nslookup kubernetes.default 2>&1 | grep -qi address && echo OK || echo FAIL"] }]
  restartPolicy: Never
EOF
  local i; for i in $(seq 1 20); do
    [ "$(kc "$c" -n default get pod fleet-dnstest -o jsonpath='{.status.phase}' 2>/dev/null)" = "Succeeded" ] && break; sleep 3
  done
  kc "$c" -n default logs fleet-dnstest 2>/dev/null | tr -d '\r' | tail -1
}

check() {
  local c=$1
  hdr "CLUSTER $c"
  ensure_jump "$c" || return
  # CAPI layer (mgmt-side) — may not exist if the Root does not manage it (e.g. mgmt-child, the recursive
  # rung: we reach it via its kubeconfig but it is not a CAPI Cluster of the Root).
  if kubectl -n $NS get cluster "$c" >/dev/null 2>&1; then
    local phase cpr
    phase=$(kubectl -n $NS get cluster "$c" -o jsonpath='{.status.phase}' 2>/dev/null)
    cpr=$(kubectl -n $NS get cluster "$c" -o jsonpath='{.status.controlPlaneReady}' 2>/dev/null)
    [ "$cpr" = "true" ] && ok "CAPI: phase=$phase controlPlaneReady=true" || no "CAPI: phase=$phase controlPlaneReady=$cpr"
  else
    inf "CAPI: n/a (not a Root-managed Cluster — reached via its kubeconfig)"
  fi
  # Nodes (with names + roles + the real KubeVirt hypervisor node each VM runs on)
  local nodes ready
  nodes=$(kc "$c" get nodes --no-headers 2>/dev/null); ready=$(echo "$nodes" | grep -cw Ready)
  if [ "$ready" -ge 1 ]; then
    ok "nodes Ready: $ready"
    echo "$nodes" | awk 'NF{print $1"\t"$2"\t"$3}' | while IFS=$'\t' read -r n st role; do
      rn=$(vmi_node "$n")
      if [ -n "$rn" ]; then li "$n  $st  ($role)  → VM on hypervisor node: $rn"; else li "$n  $st  ($role)"; fi
    done
  else
    no "nodes: $(echo "$nodes" | head -1)"
  fi
  # CNI (with pod names + status)
  local cnipods; cnipods=$(kc "$c" -n kube-system get pods --no-headers 2>/dev/null | grep -iE 'calico|cilium')
  local cni; cni=$(echo "$cnipods" | grep -c Running)
  if [ "$cni" -ge 1 ]; then
    ok "CNI pods Running: $cni"
    echo "$cnipods" | awk 'NF{print "      - "$1"  ("$3")"}' | head
  else
    no "CNI: no Running pods"
  fi
  # Cross-node DNS (MTU)
  local d; d=$(dns_test "$c"); [ "$d" = "OK" ] && ok "cross-node DNS (MTU): OK" || no "cross-node DNS: $d  <- check MTU (FLEET-KUBEVIRT-NETWORKING.md)"
  # StorageClass (with names) — filter kubectl's "No resources found" so it is not miscounted as a class
  local scs; scs=$(kc "$c" get storageclass --no-headers 2>/dev/null | grep -vi 'no resources found')
  local sc; sc=$(echo "$scs" | grep -c .)
  if [ "$sc" -ge 1 ]; then
    ok "StorageClasses: $sc"
    echo "$scs" | awk 'NF{print "      - "$1}'
  else
    warn "StorageClass: none (PVCs stay Pending)"
  fi
  # Own ArgoCD — PROBE by real app presence (no role gating): rows carry the Sync/Health columns, so
  # grepping Synced|OutOfSync skips error lines when there is no argocd ns. Run by regional AND management.
  local appsout; appsout=$(kc "$c" -n argocd get applications --no-headers 2>/dev/null | grep -E 'Synced|OutOfSync')
  local apps; apps=$(echo "$appsout" | grep -c .)
  if [ "${apps:-0}" -ge 1 ] && [ -n "$appsout" ]; then
    ok "ArgoCD apps: $apps"
    echo "$appsout" | while read -r name sync health _; do
      if [ "$sync" = "Synced" ] && [ "$health" = "Healthy" ]; then echo "      - $name  $sync/$health"
      else echo "      $(c0 '1;33' '⚠') $name  $sync/$health"; fi
    done
  else
    inf "ArgoCD: no own apps (no decentralized GitOps here)"
  fi
  # vClusters — PROBE by vcluster-* namespaces (no role gating): hosted by role=regional; a management
  # correctly returns 0 (it does not host tenants).
  local vcs; vcs=$(kc "$c" get ns --no-headers 2>/dev/null | grep -c '^vcluster-')
  if [ "${vcs:-0}" -ge 1 ]; then
    ok "vClusters: $vcs"
    kc "$c" get pods -A --no-headers 2>/dev/null | grep vcluster- | awk '{print "      - "$2"  ("$4")"}' | head
  else
    inf "vClusters: 0 (this cluster does not host tenants)"
  fi
}

list_vclusters() {
  hdr "ALL vClusters in the fleet"
  local c
  for c in $ALL; do
    ensure_jump "$c" >/dev/null 2>&1 || continue
    local out; out=$(kc "$c" get ns --no-headers 2>/dev/null | grep '^vcluster-')
    [ -n "$out" ] || continue            # only show clusters that ACTUALLY host vClusters
    echo "  [$c]"
    echo "$out" | awk '{print "    -",$1,"("$2")"}'
  done
}

vc_one() {  # rich card for one vCluster: where it comes from, what runs, what it exposes, how to operate it
  local c=$1 ns=$2
  local rest=${ns#vcluster-}; local env=${rest##*-}; local tenant=${rest%-*}
  echo -e "    $(c0 '1;36' "● $ns")  (tenant=$tenant env=$env)"
  # FROM (git provenance): root tenants live under tenants/, host-cluster ones under clusters/regions/
  local scope; [ "$c" = "@root" ] && scope="tenants" || scope="clusters/regions"
  local src; src=$(grep -rls "name: ${tenant}$" "$scope" 2>/dev/null | while read -r f; do grep -qE "environment:[[:space:]]*${env}([[:space:]]|$)" "$f" && echo "$f"; done | head -1)
  local domain api web
  if [ -n "$src" ]; then
    domain=$(awk '/^[[:space:]]*domain:/{print $2; exit}' "$src")
    api=$(awk '/api:/{f=1} f&&/version:/{gsub(/"/,"",$2);print $2;exit}' "$src")
    web=$(awk '/web:/{w=1} w&&/version:/{gsub(/"/,"",$2);print $2;exit}' "$src")
  fi
  echo "      from (git):  ${src:-<source file not found>}${domain:+   domain=$domain}"
  # MANAGED BY: the ArgoCD apps for this tenant (Root's central ArgoCD, or the host cluster's own one)
  local apps; apps=$(q "$c" -n argocd get applications --no-headers 2>/dev/null | awk -v t="$tenant-$env" '$1 ~ ("(vcluster|wl|route|eso)-" t "$") {printf "%s(%s/%s) ", $1,$2,$3}')
  echo "      managed by:  ${apps:-<none>}"
  # RUNS: which workload components are present in the host-side namespace (vCluster syncs them here)
  local pods comp run; pods=$(q "$c" -n "$ns" get pods --no-headers 2>/dev/null)
  comp=""
  echo "$pods" | grep -q "customer-api"     && comp="$comp customer-api"
  echo "$pods" | grep -q "customer-web"     && comp="$comp customer-web"
  echo "$pods" | grep -q "postgres"         && comp="$comp postgres"
  echo "$pods" | grep -q "coredns"          && comp="$comp coredns"
  echo "$pods" | grep -q "external-secrets" && comp="$comp eso"
  echo "$pods" | grep -qE "^${ns}-0|vcluster" && comp="$comp vcluster-cp"
  run=$(echo "$pods" | grep -c Running)
  echo "      runs:       ${comp:- (none)}   [${run:-0} pods Running${api:+, api $api, web $web}]"
  # EXPOSES: external HTTPS — the host-side HTTPRoute hostnames (routes-appset deploys them here).
  # Regional/recursive host clusters may not have the Gateway API CRD; kc merges stderr, so filter errors.
  local routeout hosts; routeout=$(q "$c" -n "$ns" get httproute -o jsonpath='{range .items[*]}{.spec.hostnames}{" "}{end}' 2>/dev/null)
  if echo "$routeout" | grep -qiE "error|terminated|doesn.t have|no resources"; then
    echo "      exposes:    <no HTTPRoute — Gateway API not present on this cluster>"
  else
    hosts=$(echo "$routeout" | tr -d '[]"' | xargs 2>/dev/null)
    echo "      exposes:    ${hosts:-<no HTTPRoute>}"
  fi
  # ACCESS: its own kubeconfig (per-tenant control plane) — how you actually operate the vCluster
  echo "      access:     vcluster connect $ns -n $ns   (kubeconfig: secret vc-$ns, key config)"
}

vc_info() {  # rich listing of EVERY vCluster in the fleet: provenance, workloads, exposure, access
  hdr "vClusters — where they come from, what runs, what they expose, how to operate them"
  local c label nss ns
  for c in @root $ALL; do
    if [ "$c" = "@root" ]; then label="ROOT (centralized, in-cluster)"; else ensure_jump "$c" >/dev/null 2>&1 || continue; label="$c (CAPI host cluster, via jump pod)"; fi
    nss=$(q "$c" get ns --no-headers 2>/dev/null | awk '/^vcluster-/{print $1}')
    [ -n "$nss" ] || continue
    echo; echo -e "  $(c0 '1;35' "▼ host: $label")"
    while read -r ns; do [ -n "$ns" ] && vc_one "$c" "$ns"; done <<< "$nss"
  done
}

list_vms() {  # every KubeVirt guest node (VM) across the fleet and the REAL hypervisor node it runs on
  hdr "KubeVirt VMs → real hypervisor node"
  kubectl get vmi -A -o custom-columns='NAMESPACE:.metadata.namespace,VM (guest node):.metadata.name,PHASE:.status.phase,REAL NODE:.status.nodeName' 2>/dev/null \
    || warn "no VirtualMachineInstances found (is KubeVirt running?)"
}

clean() { kubectl -n $NS delete pod -l app=fleet-test-jump --ignore-not-found 2>&1; echo "jump pods deleted (the fleet-dnstest pods are recreated clean on the next dns test)."; }

cmd=${1:-demo}; shift || true
ALL="$(discover_clusters)"
[ -z "$ALL" ] && { warn "no *-kubeconfig secrets found in ns $NS (are there any clusters created?)"; exit 1; }
case "$cmd" in
  check)   t=${1:-all}; if [ "$t" = all ]; then fleet_banner; for c in $ALL; do check "$c"; done; else check "$t"; fi ;;
  vclusters) fleet_banner; list_vclusters ;;
  vc-info) vc_info ;;
  vms)     list_vms ;;
  dns)     ensure_jump "$1" && { echo -n "cross-node DNS $1: "; dns_test "$1"; } ;;
  kc)      c=$1; shift; ensure_jump "$c" && kc "$c" "$@" ;;
  vc)      c=$1; v=$2; shift 2; ensure_jump "$c" && kc "$c" -n "$v" exec "deploy/$v" -- /bin/sh -c "kubectl $*" 2>&1 || warn "to enter the vCluster use: vcluster connect <v> -n <v> (from the host)" ;;
  demo)    fleet_banner; for c in $ALL; do check "$c"; done; list_vclusters ;;
  clean)   clean ;;
  *) echo "usage: cli/fleet-test {check [cluster|all]|vclusters|vc-info|vms|dns <c>|kc <c> <args>|demo|clean}"; exit 1 ;;
esac
