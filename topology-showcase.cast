[0.000123, "o", "      srv-rk1-nvme-01       Ready   <none>                      30d    v1.35.5+k3s1   192.168.178.131   <none>   Ubuntu 24.04.1 LTS   6.1.0-1025-rockchip   containerd://2.2.3-k3s1\r\n      srv-rk1-nvme-02       Ready   <none>                      30d    v1.35.5+k3s1   192.168.178.48    <none>   Ubuntu 24.04.1 LTS   6.1.0-1025-rockchip   containerd://2.2.3-k3s1\r\n"]
