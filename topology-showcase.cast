[0.000067, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m3. Each host runs its OWN ArgoCD + its OWN vClusters (MODELS 3 & 4)\u001b[0m\r\n"]
[0.000045, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000056, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m Decentralized GitOps: the management ArgoCD only creates clusters; each created host (role=management) gets its own ArgoCD (via CAAPH) seeded with a region-root, and provisions ITS region's vClusters locally вЂ” no central SPOF. A host promoted to management is the 'management-child' rung.\r\n\r\n"]
[1.719598, "o", "  \u001b[34mвЂў\u001b[0m Management-role clusters (each runs its own ArgoCD):\r\n"]
[1.455853, "o", "      \u001b[35mhost-mgmt\u001b[0m (region=none) в†’ local ArgoCD apps: 1\r\n  \u001b[32mвњ”\u001b[0m ArgoCD is sharded per cluster вЂ” the management plane is not a single point of failure.\r\n"]
[0.000497, "o", "\r\n\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m4. vCluster placement вЂ” centralized (Root) vs decentralized (regional)\u001b[0m\r\n\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[33mв„№пёЏ Concept:\u001b[0m The SAME tenant chart (vCluster + Postgres + api + web + quota + netpol) runs either directly on the Root (centralized) or inside a regional host (decentralized). Same contract, different placement.\r\n\r\n"]
[1.502984, "o", "  \u001b[34mвЂў\u001b[0m CENTRALIZED vClusters (running directly on the Root cluster):\r\n"]
[0.32486, "o", "      вЂў vcluster-tenant-a-acceptance\r\n      вЂў vcluster-tenant-a-dev\r\n      вЂў vcluster-tenant-a-prod\r\n      вЂў vcluster-tenant-b-dev\r\n      вЂў vcluster-tenant-c-dev\r\n      вЂў vcluster-tenant-x-dev\r\n      вЂў vcluster-tenant-y-dev\r\n"]
[0.012133, "o", "\r\n  \u001b[34mвЂў\u001b[0m DECENTRALIZED vClusters (inside each regional host, queried via jump pod):\r\n"]
[1.52205, "o", "  \u001b[32mвњ”\u001b[0m Tenants are sharded across regional host VMs вЂ” the decentralized fleet model.\r\n"]
[0.000068, "o", "\r\n"]
[0.000084, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000123, "o", " \u001b[1m5. Variants validated: HA control plane & per-cluster CNI experiments\u001b[0m\r\n\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000007, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m On the same substrate we A/B-tested control-plane HA (etcd quorum) and three CNIs. On nested KubeVirt the per-VM masquerade interfered with cross-VM overlay traffic (IPIP/Cilium); Calico-VXLAN is what we validated end-to-end (README В§3.1 вЂ” framed as an experiment, not a verdict).\r\n"]
[0.000012, "o", "\r\n"]
[1.502105, "o", "  \u001b[34mвЂў\u001b[0m Control-plane replicas per cluster (HA = 3 в†’ etcd quorum 2/3):\r\n"]
[0.161002, "o", "      host-euw1-control-plane   1     1     true\r\n      host-mgmt-control-plane   1     1     true\r\n"]
[0.004255, "o", "\r\n"]
[0.000036, "o", "  \u001b[34mвЂў\u001b[0m CNI chosen per cluster (the experiment knob, spec.cni):\r\n"]
[0.171877, "o", "      host-euw1   calico-vxlan\r\n      host-mgmt   calico-vxlan\r\n"]
[0.00438, "o", "  \u001b[32mвњ”\u001b[0m CNI is a per-cluster field; multi-VM clusters standardized on calico-vxlan after the experiment.\r\n"]
[0.000035, "o", "\r\n"]
[0.000075, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m6. Management-of-managements: host-mgmt CREATES its own child (MODEL 6)\u001b[0m\r\n"]
[0.000068, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000028, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m host-mgmt is not just a workload host вЂ” it runs FULL CAPI and creates ITS OWN host cluster (mgmt-child). The child's VMs run on the Root's KubeVirt via CAPK external-infra (the only KVM node). Recursive fleet: a management cluster spawning more clusters, all GitOps.\r\n\r\n"]
[1.502991, "o", "  \u001b[34mвЂў\u001b[0m host-mgmt runs CAPI (it IS a management cluster вЂ” providers Ready):\r\n"]
