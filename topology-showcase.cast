[0.000032, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000024, "o", " \u001b[1m3. Each host runs its OWN ArgoCD + its OWN vClusters (MODELS 3 & 4)\u001b[0m\r\n"]
[0.000088, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[33mв„№пёЏ Concept:\u001b[0m Decentralized GitOps: the management ArgoCD only creates clusters; each created host (role=management) gets its own ArgoCD (via CAAPH) seeded with a region-root, and provisions ITS region's vClusters locally вЂ” no central SPOF. A host promoted to management is the 'management-child' rung.\r\n\r\n"]
[1.641571, "o", "  \u001b[34mвЂў\u001b[0m Management-role clusters (each runs its own ArgoCD):\r\n"]
[1.283922, "o", "      \u001b[35mhost-mgmt\u001b[0m (region=none) в†’ local ArgoCD apps: 1\r\n  \u001b[32mвњ”\u001b[0m ArgoCD is sharded per cluster вЂ” the management plane is not a single point of failure.\r\n"]
[0.000103, "o", "\r\n"]
[0.000046, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000036, "o", " \u001b[1m4. vCluster placement вЂ” centralized (Root) vs decentralized (regional)\u001b[0m\r\n"]
[0.000053, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000045, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m The SAME tenant chart (vCluster + Postgres + api + web + quota + netpol) runs either directly on the Root (centralized) or inside a regional host (decentralized). Same contract, different placement.\r\n\r\n"]
[1.501661, "o", "  \u001b[34mвЂў\u001b[0m CENTRALIZED vClusters (running directly on the Root cluster):\r\n"]
[0.143021, "o", "      вЂў vcluster-tenant-a-acceptance\r\n      вЂў vcluster-tenant-a-dev\r\n      вЂў vcluster-tenant-a-prod\r\n      вЂў vcluster-tenant-b-dev\r\n      вЂў vcluster-tenant-c-dev\r\n      вЂў vcluster-tenant-x-dev\r\n      вЂў vcluster-tenant-y-dev\r\n"]
[0.003664, "o", "\r\n"]
[0.00001, "o", "  \u001b[34mвЂў\u001b[0m DECENTRALIZED vClusters (inside each regional host, queried via jump pod):\r\n"]
[1.043996, "o", "  \u001b[32mвњ”\u001b[0m Tenants are sharded across regional host VMs вЂ” the decentralized fleet model.\r\n"]
[0.00008, "o", "\r\n"]
[0.000058, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m5. Variants validated: HA control plane & per-cluster CNI experiments\u001b[0m\r\n"]
[0.000111, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000013, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m On the same substrate we A/B-tested control-plane HA (etcd quorum) and three CNIs. On nested KubeVirt the per-VM masquerade interfered with cross-VM overlay traffic (IPIP/Cilium); Calico-VXLAN is what we validated end-to-end (README В§3.1 вЂ” framed as an experiment, not a verdict).\r\n"]
[0.000006, "o", "\r\n"]
[1.50234, "o", "  \u001b[34mвЂў\u001b[0m Control-plane replicas per cluster (HA = 3 в†’ etcd quorum 2/3):\r\n"]
[0.137752, "o", "      host-euw1-control-plane   1     1     true\r\n      host-mgmt-control-plane   1     1     true\r\n"]
[0.00331, "o", "\r\n"]
[0.000012, "o", "  \u001b[34mвЂў\u001b[0m CNI chosen per cluster (the experiment knob, spec.cni):\r\n"]
[0.134704, "o", "      host-euw1   calico-vxlan\r\n      host-mgmt   calico-vxlan\r\n"]
[0.003313, "o", "  \u001b[32mвњ”\u001b[0m CNI is a per-cluster field; multi-VM clusters standardized on calico-vxlan after the experiment.\r\n"]
[0.000101, "o", "\r\n"]
[0.000073, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m6. Recursion: host-mgmt creates a child AND gives it its OWN stack (MODEL 6)\u001b[0m\r\n"]
[0.000096, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[33mв„№пёЏ Concept:\u001b[0m host-mgmt is not just a workload host вЂ” it runs FULL CAPI+CAAPH and creates ITS OWN host cluster (mgmt-child), then delivers it the SAME stack the Root gives its regionals (ArgoCD + region-root + CNI), one rung down. mgmt-child ends up decentralized (own ArgoCD, no SPOF) hosting its own tenant vCluster. Whole chain validated CLEAN-ROOM (deleted everything, rebuilt from git).\r\n\r\n"]
[1.501774, "o", "  \u001b[34mвЂў\u001b[0m host-mgmt runs CAPI + CAAPH (providers Ready вЂ” incl. addon=helm, so it installs ArgoCD on its OWN children):\r\n"]
[1.073489, "o", "      coreprovider.operator.cluster.x-k8s.io/cluster-api ready=True\r\n      bootstrapprovider.operator.cluster.x-k8s.io/kubeadm ready=True\r\n      controlplaneprovider.operator.cluster.x-k8s.io/kubeadm ready=True\r\n      infrastructureprovider.operator.cluster.x-k8s.io/kubevirt ready=True\r\n      addonprovider.operator.cluster.x-k8s.io/helm ready=True\r\n"]
[0.000483, "o", "\r\n"]
