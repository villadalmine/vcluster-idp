[0.000074, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n \u001b[1m3. Cluster Provisioning: Host Clusters vs. Child Managements\u001b[0m\r\n"]
[0.000104, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000018, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m Crossplane v2 and CAPI provision virtual clusters on the VMs. We distinguish between regular Host Clusters (workload hosts) and Child Management Clusters (which run their own ArgoCD).\r\n\r\n"]
[1.501896, "o", "  \u001b[34mвЂў\u001b[0m Listing Crossplane HostCluster (XR) instances:\r\n"]
[0.186792, "o", "      host-a      host                    True   True\r\n      host-b      host                    True   True\r\n      host-c      host                    True   True\r\n      host-euw1   management   eu-west1   True   True\r\n      host-mgmt   management              True   True\r\n"]
[0.004585, "o", "\r\n  \u001b[34mвЂў\u001b[0m Listing corresponding CAPI Clusters:\r\n"]
[0.284801, "o", "      host-a      Provisioned   true   true\r\n      host-b      Provisioned   true   true\r\n      host-c      Provisioned   true   true\r\n      host-euw1   Provisioned   true   true\r\n      host-mgmt   Provisioned   true   true\r\n"]
[0.006228, "o", "\r\n"]
[0.000066, "o", "  \u001b[32mвњ”\u001b[0m We have 2 Management clusters (host-mgmt, host-euw1) and 3 Host clusters (host-a/b/c).\r\n"]
[0.0001, "o", "\r\n"]
[0.000053, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000018, "o", " \u001b[1m4. Tenant Placement: Centralized vs. Decentralized (Regional) vClusters\u001b[0m\r\n"]
[0.000056, "o", "\u001b[36m\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
[0.000026, "o", " \u001b[33mв„№пёЏ Concept:\u001b[0m We support two tenancy models: Centralized vClusters (running directly on the Root Management Cluster) and Decentralized vClusters (running inside virtual regional hosts).\r\n\r\n"]
[1.503667, "o", "  \u001b[34mвЂў\u001b[0m Checking CENTRALIZED tenants (running directly on the Root Management Cluster):\r\n"]
